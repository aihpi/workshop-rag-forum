# Copy this file to .env and fill in your values. .env is gitignored.
#
# OpenAI-compatible embedding endpoint (locally hosted at HPI / KI-Servicezentrum).
OPENAI_API_KEY=your_key_here
OPENAI_API_BASE=http://localhost:8000/v1

# Embedding model. minilm-embedding is small/fast and used for the 250615-turbovec meeting.
# Swappable: qwen3-vl-embedding-8b, octen-embedding-8b
OPENAI_EMBEDDING_MODEL=minilm-embedding

# Optional: embedding dimensionality. If unset, it is auto-detected from the API response.
# OPENAI_EMBEDDING_DIM=384
